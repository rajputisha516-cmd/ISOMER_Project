# Backend .env Example Configuration

# Flask Application
FLASK_APP=app.py
FLASK_ENV=development
DEBUG=True

# Security - CHANGE THIS IN PRODUCTION!
SECRET_KEY=dev-secret-key-change-in-production-12345

# Database Configuration
# SQLite (development)
SQLALCHEMY_DATABASE_URI=sqlite:///surveillance.db

# PostgreSQL (production - optional)
# SQLALCHEMY_DATABASE_URI=postgresql://user:password@localhost/surveillance

# CORS Settings
# Update for production
CORS_ORIGINS=http://localhost:3000,http://localhost:5000,http://127.0.0.1:3000

# Server Configuration
HOST=0.0.0.0
PORT=5000
WORKERS=4

# Model Configuration
MODEL_NAME=yolov8n-seg
# Model variants: yolov8n-seg, yolov8s-seg, yolov8m-seg, yolov8l-seg
# nano (n) = fastest, light (l) = most accurate

# Detection Settings
CONFIDENCE_THRESHOLD=0.5        # 0.0-1.0 (lower = more detections)
NMS_THRESHOLD=0.45              # Non-Maximum Suppression threshold
MODEL_CONFIDENCE=0.5            # Model prediction confidence

# Video Processing
VIDEO_FRAME_WIDTH=640           # Frame width
VIDEO_FRAME_HEIGHT=480          # Frame height
VIDEO_FPS=30                    # Frames per second target
OPTICAL_FLOW_SCALE=0.5          # Optical flow scale factor

# Motion Detection
MOTION_THRESHOLD=0.1            # 0.0-1.0 (motion sensitivity)
OPTICAL_FLOW_PYR_SCALE=0.5      # Farneback parameter

# Intrusion Detection
INTRUSION_COOLDOWN=5            # Seconds between intrusion alerts

# GPU/Device Configuration
# cuda = GPU (recommended), cpu = CPU only
DEVICE=cuda

# Logging
LOG_LEVEL=INFO                  # DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# File Management
UPLOAD_FOLDER=uploads           # Upload directory
CAPTURE_DIR=captures            # Screenshots directory
HISTORY_DIR=history             # History directory
LOG_DIR=logs                    # Logs directory
MAX_CONTENT_LENGTH=524288000    # 500MB in bytes

# Session Configuration
PERMANENT_SESSION_LIFETIME=604800 # 7 days in seconds
SESSION_COOKIE_SECURE=False     # True for HTTPS only
SESSION_COOKIE_HTTPONLY=True    # Prevent JavaScript access
SESSION_COOKIE_SAMESITE=Lax     # CSRF protection

# Allowed File Extensions
ALLOWED_VIDEO_EXTENSIONS=mp4,avi,mov,flv,wmv,mkv

# Database Settings
SQLALCHEMY_TRACK_MODIFICATIONS=False
SQLALCHEMY_ECHO=False           # Log SQL queries (True for debugging)

# Alert Configuration
ALERT_RETENTION_DAYS=30         # Keep alerts for 30 days
AUTO_DELETE_OLD_ALERTS=True

# Detection Configuration
CLASSES_TO_DETECT=person,car,truck,bus,bicycle,motorcycle,dog,cat

# Email Configuration (Optional - for alerts)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_DEFAULT_SENDER=noreply@isomer.local

# Telegram Bot (Optional - for alerts)
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_CHAT_ID=your-chat-id

# Feature Flags
ENABLE_EMAIL_ALERTS=False
ENABLE_TELEGRAM_ALERTS=False
ENABLE_HEATMAP=True
ENABLE_TRACKING=True

# Performance Tuning
BATCH_SIZE=1                    # Number of frames to process together
QUEUE_MAX_SIZE=100              # Max video frame queue size
DETECTION_INTERVAL=1            # Process every N frames

# API Keys (if integrating with external services)
SLACK_WEBHOOK_URL=
WEBHOOK_URL=

# Testing
TESTING=False
TEST_DATABASE_URI=sqlite:///test_surveillance.db
